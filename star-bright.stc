# 677 ALF And / Alpheratz
# TODO: Update barycentre position
# Radius and Temperature from Ryabchikova et al. (1999), A&A 351, p.963-972
#   "Orbital elements and abundance analyses of the double-lined spectroscopic binary alpha Andromedae"
#   https://scixplorer.org/abs/1999A%26A...351..963R/abstract
# Orbit and masses from Branham (2017), MNRAS 464 (1), p.1095-1101
#   "A three-dimensional orbit for the binary star Alpha Andromedae"
#   https://academic.oup.com/mnras/article/464/1/1095/2268699
#   https://scixplorer.org/abs/2017MNRAS.464.1095B/abstract
# SpectralType, AppMag (V-band), and BoloCorrection from Piccotti et al. (2020), MNRAS 492 (2), p.2709-2721
#   "A study of the physical properties of SB2s with both the visual and spectroscopic orbits"
#   https://academic.oup.com/mnras/article/492/2/2709/5695748
#   https://scixplorer.org/abs/2020MNRAS.492.2709P/abstract
Barycenter 677 "Alpheratz:Sirrah:ALF And:21 And:DEL Peg:ADS 94 A:CCDM J00083+2905A"  # Traditional star name
{
	RA 2.096534
	Dec 29.090828
	Distance 97.015764
}

# Rotation period from Kochukhov et al. (2021), MNRAS 506 (4), pp.5328-5344
#   “TESS survey of rotational and pulsational variability of mercury–manganese stars”
#   https://academic.oup.com/mnras/article/506/4/5328/6325560
#   https://scixplorer.org/abs/2021MNRAS.506.5328K/abstract
"Alpheratz A:Sirrah A:ALF And A:21 And A:DEL Peg A:ADS 94 Aa:CCDM J00083+2905Aa"
{
	Radius<rS> 2.7                      # ± 0.4; from luminosity and temperature
	SpectralType "B8IV-VHgMn"
	AppMag 2.221
	BoloCorrection -0.60
	Temperature 13800                   # ± 125

	OrbitBarycenter "ALF And"
	EllipticalOrbit
	{
		Epoch          2447763.097745
		Period<d>           96.69342
		SemiMajorAxis        0.2496     # 23.917 ± 0.127 mas, mass ratio = (3.630 ± 0.201):(1.875 ± 0.096)
		Eccentricity         0.525855
		Inclination         39.093
		AscendingNode      200.782
		ArgOfPericenter    145.854
	}
	UniformRotation                     # assume alignment with orbital plane
	{
		Period<d>            2.38337    # ± 0.00017
		Inclination         39.093
		AscendingNode      200.782
	}
}

"Alpheratz B:Sirrah B:ALF And B:21 And B:DEL Peg B:ADS 94 Ab:CCDM J00083+2905Ab" 
{
	Radius<rS> 1.65                     # ± 0.3; from luminosity and temperature
