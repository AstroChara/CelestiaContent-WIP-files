	OrbitBarycenter "ALF And"
	EllipticalOrbit
	{
		Epoch          2447763.097745
		Period<d>           96.69342
		SemiMajorAxis        0.4832     # 23.917 ± 0.127 mas, mass ratio = (3.630 ± 0.201):(1.875 ± 0.096)
		Eccentricity         0.525855
		Inclination         39.093
		AscendingNode      200.782
		ArgOfPericenter    325.854
	}
}

